OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0

MAX_CONCURRENT_REQUESTS=20
MAX_DEPTH=3
BATCH_SIZE=500
REQUEST_TIMEOUT=30
REQUEST_DELAY_MIN=0.5
REQUEST_DELAY_MAX=2.0
MAX_RETRIES=3

LLM_FALLBACK_ENABLED=true
LLM_MAX_INPUT_CHARS=1500
LLM_SUPERVISOR_ENABLED=true
LLM_ERROR_THRESHOLD=10

OUTPUT_DIR=./output
LOG_LEVEL=INFO
LOG_FILE=./output/crawler.log

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_MAX_BROWSERS=5

# Proxy (opsional). Format: socks5://host:port atau socks5://user:pass@host:port atau http://host:port
# Untuk multiple proxy, pisahkan dengan koma
PROXY_ENABLED=false
PROXY_LIST=socks5://127.0.0.1:1080
PROXY_ROTATE=true
