OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini
OPENAI_TEMPERATURE=0.0

# Tavily Search API — https://tavily.com (1000 req/month free)
# Primary search engine. Set this for best results.
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# Jina AI Reader — https://jina.ai (free without key, key adds higher rate limits)
# Used as fallback PDF parser and for JS-heavy page extraction.
JINA_API_KEY=jina_your_jina_api_key_here

# Firecrawl — https://firecrawl.dev (primary PDF parser, 5x faster via Rust engine)
# GET 500 free credits at https://firecrawl.dev
# Used for /parse endpoint: downloads PDF bytes → returns clean Markdown
FIRECRAWL_API_KEY=fc-your_firecrawl_api_key_here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

MAX_CONCURRENT_REQUESTS=20
MAX_DEPTH=3
BATCH_SIZE=500
REQUEST_TIMEOUT=30
REQUEST_DELAY_MIN=0.5
REQUEST_DELAY_MAX=2.0
MAX_RETRIES=3

LLM_FALLBACK_ENABLED=true
LLM_MAX_INPUT_CHARS=1500
LLM_SUPERVISOR_ENABLED=true
LLM_ERROR_THRESHOLD=10

OUTPUT_DIR=./output
LOG_LEVEL=INFO
LOG_FILE=./output/crawler.log

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_MAX_BROWSERS=5

# Proxy (opsional). PROXY_LIST harus format JSON array: ["socks5://host:port"] atau []
PROXY_ENABLED=false
PROXY_LIST=[]
PROXY_ROTATE=true

# OpenSERP self-hosted search backend
# Jalankan Docker: docker run -p 127.0.0.1:7000:7000 -it karust/openserp serve -a 0.0.0.0 -p 7000
OPENSERP_BASE_URL=http://localhost:7000
OPENSERP_ENABLED=true

# OpenHands — AI coding agent untuk generate parser otomatis per domain
# Install: pip install openhands-ai && python -m openhands.server.listen
# Jika tidak jalan, fallback ke LLM (OpenAI) otomatis
OPENHANDS_BASE_URL=http://localhost:3000
OPENHANDS_PARSER_ENABLED=true
OPENHANDS_PARSER_MODEL=codex-mini-latest
